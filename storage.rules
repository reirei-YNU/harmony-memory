rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isMemberOfGroup(groupId) {
      return request.auth != null &&
        request.auth.uid in firestore.get(
          /databases/(default)/documents/groups/$(groupId)
        ).data.memberIds;
    }

    match /groups/{groupId}/songs/{songId}/{fileName} {
      allow read: if isMemberOfGroup(groupId);
      // 25MB per take is generous headroom for a compressed opus recording
      // while still protecting the group's shared storage quota.
      allow write: if isMemberOfGroup(groupId) &&
        request.resource.size < 25 * 1024 * 1024 &&
        request.resource.contentType.matches('audio/.*');
      allow delete: if isMemberOfGroup(groupId);
    }
  }
}
